---
import type { Post } from '~/types';
import { APP_BLOG } from 'astrowind:config';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="tm-articles tm-articles-blog">
  {
    posts.map((post, i) => {
      const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '#';
      const read = post.readingTime ? `${post.readingTime} min` : '';
      const cat = post.category?.title ?? '';
      return (
        <a class="tm-article" href={link}>
          <span class="tm-article-idx">[{String(i + 1).padStart(2, '0')}]</span>
          <span class="tm-article-date">{getFormattedDate(post.publishDate)}</span>
          {cat && <span class="tm-article-cat">#{cat.toLowerCase()}</span>}
          <span class="tm-article-title">{post.title}</span>
          {post.excerpt && <span class="tm-article-excerpt">{post.excerpt}</span>}
          <span class="tm-article-read">{read}</span>
          <span class="tm-article-arrow">→</span>
        </a>
      );
    })
  }
</div>
