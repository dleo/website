---
import Image from '~/components/common/Image.astro';
import StructuredData from '~/components/common/StructuredData.astro';

import { SITE, APP_BLOG } from 'astrowind:config';
import { getPermalink, getBlogPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;

const siteUrl = String(new URL('/', SITE.site)).replace(/\/$/, '');
const postUrl = String(url);
const authorName = post.author || 'David Lopez';
const postImage =
  post.image && typeof post.image !== 'string' && 'src' in post.image
    ? String(new URL(post.image.src, SITE.site))
    : typeof post.image === 'string'
      ? post.image
      : undefined;

const blogPosting: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${postUrl}#blogposting`,
  headline: post.title,
  description: post.excerpt,
  datePublished: post.publishDate instanceof Date ? post.publishDate.toISOString() : String(post.publishDate),
  ...(post.updateDate
    ? { dateModified: post.updateDate instanceof Date ? post.updateDate.toISOString() : String(post.updateDate) }
    : {}),
  author: { '@id': `${siteUrl}/#person`, '@type': 'Person', name: authorName },
  publisher: { '@id': `${siteUrl}/#person` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  ...(postImage ? { image: postImage } : {}),
  ...(post.category ? { articleSection: post.category.title } : {}),
  ...(post.tags && post.tags.length ? { keywords: post.tags.map((t) => t.title).join(', ') } : {}),
};

const breadcrumbList: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}${getBlogPermalink()}` },
    { '@type': 'ListItem', position: 3, name: post.title, item: postUrl },
  ],
};

const initials = authorName
  .split(' ')
  .map((w) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

const categoryLink = post.category && APP_BLOG?.category?.isEnabled ? getPermalink(post.category.slug, 'category') : null;
---

<StructuredData schema={blogPosting} />
<StructuredData schema={breadcrumbList} />

<nav class="tm-blog-breadcrumbs" aria-label="Breadcrumb">
  <a href="/">~</a>
  <span class="sep">/</span>
  <a href={getBlogPermalink()}>blog</a>
  <span class="sep">/</span>
  <span>{post.slug ?? post.permalink}</span>
</nav>

<article class="tm-post">
  <div class="tm-post-filename">~/blog/{post.slug ?? post.permalink}.md</div>

  <div class="tm-post-meta">
    <span>
      <span class="tm-comment">//</span>
      <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
    </span>
    {categoryLink ? <a href={categoryLink}>#{post.category!.title.toLowerCase()}</a> : post.category && <span>#{post.category.title.toLowerCase()}</span>}
    {post.readingTime && <span>{post.readingTime} min read</span>}
    <span>by <em>{authorName}</em></span>
  </div>

  <h1 class="tm-post-title">{post.title}</h1>

  {post.excerpt && <p class="tm-post-excerpt">{post.excerpt}</p>}

  {
    post.image && (
      <div class="tm-post-image">
        <Image
          src={post.image}
          widths={[400, 900]}
          sizes="(max-width: 900px) 400px, 900px"
          alt={post?.excerpt || ''}
          width={900}
          height={506}
          loading="eager"
          decoding="async"
        />
      </div>
    )
  }

  <div class="tm-post-prose">
    <slot />
  </div>

  <div class="tm-post-footer">
    <div class="tm-post-tags">
      {
        post.tags &&
          Array.isArray(post.tags) &&
          post.tags.map((tag) =>
            APP_BLOG?.tag?.isEnabled ? (
              <a class="tm-post-tag" href={getPermalink(tag.slug, 'tag')}>
                {tag.title.toLowerCase()}
              </a>
            ) : (
              <span class="tm-post-tag">{tag.title.toLowerCase()}</span>
            )
          )
      }
    </div>
    <div class="tm-post-share">
      <span class="tm-comment">// share</span>
      <a href={`https://x.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(post.title)}`} target="_blank" rel="noreferrer">x</a>
      <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`} target="_blank" rel="noreferrer">linkedin</a>
    </div>
  </div>

  <aside class="tm-post-author">
    <div class="tm-post-author-avatar">{initials}</div>
    <div>
      <div class="tm-post-author-name">{authorName}</div>
      <p class="tm-post-author-bio">
        Full-stack developer · fractional tech lead. 15+ years building Laravel, Vue, and AI-integrated systems.
        <a href="/#about">more about me →</a>
      </p>
    </div>
  </aside>

  <a class="tm-to-blog" href={getBlogPermalink()}>
    <span>←</span> cd ../blog
  </a>
</article>
