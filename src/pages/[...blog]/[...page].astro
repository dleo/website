---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import V2BlogLayout from '~/layouts/V2BlogLayout.astro';
import V2BlogList from '~/components/v2/V2BlogList.astro';
import V2Pagination from '~/components/v2/V2Pagination.astro';

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Blog${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<V2BlogLayout metadata={metadata} path="david@lopez:~/blog $">
  <section class="tm-blog-hero">
    <div class="tm-blog-hero-prompt">$ ls -la ~/blog/</div>
    <h1>writing.</h1>
    <p class="tm-blog-hero-sub">
      Notes on engineering, product, and the fractional-CTO life. Thoughts on what actually ships vs.
      what just sounds good in a kickoff.
    </p>
  </section>

  <section class="tm-blog-wrap">
    <V2BlogList posts={page.data} />
    <V2Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</V2BlogLayout>
