---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { blogCategoryRobots, getStaticPathsBlogCategory } from '~/utils/blog';

import V2BlogLayout from '~/layouts/V2BlogLayout.astro';
import V2BlogList from '~/components/v2/V2BlogList.astro';
import V2Pagination from '~/components/v2/V2Pagination.astro';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogCategory({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths> & { category: Record<string, string> };

const { page, category } = Astro.props as Props;

const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Category '${category.title}' ${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<V2BlogLayout metadata={metadata} path={`david@lopez:~/blog/#${category.title.toLowerCase()} $`}>
  <section class="tm-blog-hero">
    <div class="tm-blog-hero-prompt">$ grep -r "category={category.title}" ~/blog/</div>
    <h1>#{category.title.toLowerCase()}</h1>
    <p class="tm-blog-hero-sub">
      Posts filed under <em>{category.title}</em>.
    </p>
  </section>

  <section class="tm-blog-wrap">
    <V2BlogList posts={page.data} />
    <V2Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</V2BlogLayout>
